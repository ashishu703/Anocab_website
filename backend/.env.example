# Server Configuration
PORT=3000
NODE_ENV=development

# API Base URL (Used by frontend - change to your domain in production)
API_BASE_URL=http://localhost:3000

# CORS Configuration (* allows all origins, specify domain in production)
CORS_ORIGIN=*

# Admin Credentials (CHANGE THESE IN PRODUCTION!)
ADMIN_EMAIL=admin@anocab.com
ADMIN_PASSWORD=yourSecurePassword123

# Session Secret (CHANGE THIS TO A RANDOM STRING!)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/anocab

# Email Configuration (Gmail SMTP)
MAIL_USER=your-email@example.com
MAIL_PASS=your-gmail-app-password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Admin Email (for receiving notifications)
ADMIN_EMAIL=admin@example.com
